{
  "name": "tui-agent-refactor",
  "version": "0.2.0",
  "description": "A plugin-based TUI coding agent with pi-mono style session management, session-store, and slot-based UI architecture (using @earendil-works/pi-tui)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "bin": {
    "tca": "./src/cli.ts"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-vm-modules --test src/**/*.test.ts"
  },
  "keywords": [
    "tui",
    "terminal",
    "agent",
    "coding-agent",
    "llm",
    "ai",
    "pi-mono"
  ],
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.7",
    "chalk": "^5.6.2",
    "marked": "^18.0.6",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
